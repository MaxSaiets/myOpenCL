const CODE_KW     = ['код','code','python','javascript','typescript','script','скрипт',
                     'debug','fix','bug','import','function','async','bash','sql','api',
                     'git','docker','рефакторинг','traceback','syntax','error:','def ','class '];
const TASK_KW     = ['зроби','виконай','створи','реалізуй','налаштуй','встанови',
                     'запусти','збережи','запуш','push','deploy','setup','install','проект','завдання'];
const ANALYSIS_KW = ['поясни','explain','аналіз','analyze','порівняй','compare',
                     'дослідж','research','розгорнуто','детально','чому','why','як працює'];
const VERIFY_KW   = ['перевір','verify','check','підтверди','результат','готово','done'];

function detectStage(messages) {
  const nonSys = messages.filter(m => m.role !== 'system');
  if (nonSys.length === 0) return 'chat';

  const recent5 = nonSys.slice(-5);
  const last    = nonSys[nonSys.length - 1];

  // execution: recent messages have tool_calls or tool results
  const hasToolCalls   = recent5.some(m => Array.isArray(m.tool_calls) && m.tool_calls.length > 0);
  const hasToolResults = recent5.some(m => m.role === 'tool');
  if (hasToolCalls || hasToolResults) {
    const lastText = (typeof last.content === 'string' ? last.content : '').toLowerCase();
    if (last.role === 'user' && VERIFY_KW.some(kw => lastText.includes(kw))) return 'verification';
    return 'execution';
  }

  // verification: many tool results in history + user asks to verify
  const toolCount = nonSys.filter(m => m.role === 'tool').length;
  if (toolCount >= 3 && last.role === 'user') {
    const lastText = (typeof last.content === 'string' ? last.content : '').toLowerCase();
    if (VERIFY_KW.some(kw => lastText.includes(kw))) return 'verification';
  }

  // keyword classification
  const text = nonSys.filter(m => m.role === 'user')
    .map(m => typeof m.content === 'string' ? m.content : JSON.stringify(m.content))
    .join(' ').toLowerCase();
  if (CODE_KW.some(kw => text.includes(kw)))     return 'code';
  if (TASK_KW.some(kw => text.includes(kw)))     return 'task';
  if (ANALYSIS_KW.some(kw => text.includes(kw))) return 'analysis';
  return 'chat';
}

function classifyTask(messages, hasTools) {
  // If request includes tools, ALWAYS use execution chain (reliable tool calling only)
  if (hasTools) return { type: "execution", chain: CHAINS.execution() };
  const type  = detectStage(messages);
  const chain = (CHAINS[type] || CHAINS.chat)();
  return { type, chain };
}

// ── PROXY REQUEST ─────────────────────────────────────────────────────────────
async function tryBackend(backend, model, body, stream) {
  const cfg = BACKENDS[backend];
  if (!cfg || !cfg.active()) throw new Error('INACTIVE:' + backend);

  const ck = backend + '/' + model;
  if (isOnCooldown(ck)) throw new Error('COOLDOWN:' + ck);

  const modelKey = backend + '/' + model;
  const mlim = MODEL_LIMITS[modelKey] || { ctx: DEFAULT_CTX, out: DEFAULT_OUT };

  // Strip tools for backends that don't support function calling
  let tools = NO_TOOLS_BACKENDS.has(backend) ? undefined : compressTools(body.tools || undefined);
  // Sanitize tool schemas for all backends (strip anyOf, additionalProperties, $schema etc)
  if (tools) tools = sanitizeToolsForGemini(tools);
  // schema debug removed
  const toolChoice = NO_TOOLS_BACKENDS.has(backend) ? undefined : (body.tool_choice || undefined);

  // Budget = ctx limit minus output minus tools overhead minus safety margin
  const toolsTokens = tools ? estTokens(tools) : 0;
  const msgBudget   = mlim.ctx - mlim.out - toolsTokens - 500;
  const trimmedMsgs = smartCompress(body.messages || [], Math.max(msgBudget, 2000));

  let payload = { ...body, model, messages: trimmedMsgs };
  if (tools !== undefined)      payload.tools       = tools;
  else                          delete payload.tools;
  if (toolChoice !== undefined) payload.tool_choice = toolChoice;
  else                          delete payload.tool_choice;

  if (cfg.allowedParams) {
    payload = Object.fromEntries(Object.entries(payload).filter(([k]) => cfg.allowedParams.has(k)));
  }
  payload.stream = stream || false;

  // Strip params some APIs don't support
  delete payload.store;
  delete payload.user;
  delete payload.service_tier;
  delete payload.logprobs;
  delete payload.top_logprobs;
  delete payload.n;

  // Cap output tokens to model limit
  if ((payload.max_tokens || 0) > mlim.out)            payload.max_tokens = mlim.out;
  if ((payload.max_completion_tokens || 0) > mlim.out) payload.max_completion_tokens = mlim.out;
  if (!payload.max_tokens)                             payload.max_tokens = mlim.out;

  // Log compressed size
  const cmpSz = Math.round(JSON.stringify(payload).length / 1024);
  const cmpTool = Math.round(JSON.stringify(payload.tools || []).length / 1024);
  if (cmpTool > 0) console.log('[router] -> ' + backend + ' payload=' + cmpSz + 'kb tools=' + cmpTool + 'kb');
  // debug log removed

  // schema debug removed
  const res = await fetch(cfg.url, {
    method: 'POST',
    headers: cfg.headers(),
    body: JSON.stringify(payload),
  });

  if (res.status === 429) {
    const text = await res.text();
    const match = text.match(/retry[- ]after[": ]+([0-9.]+)/i) || text.match(/retry in ([0-9.]+)s/i);
    const wait = match ? Math.ceil(parseFloat(match[1])) : 60;
    setCooldown(ck, wait);
    const e = new Error('429 cooldown ' + wait + 's'); e.status = 429; throw e;
  }

  return res;
}

// ── MAIN HANDLER ──────────────────────────────────────────────────────────────
app.post('/v1/chat/completions', async (req, res) => {
  stats.requests++;
  const { messages = [], stream = false } = req.body;
  const { type, chain } = classifyTask(messages, (req.body.tools || []).length > 0);
  stats.byType[type] = (stats.byType[type] || 0) + 1;
  const _bsz=JSON.stringify(req.body).length; const _tsz=JSON.stringify(req.body.tools||[]).length;
  console.log('[router] task=' + type + ' body=' + Math.round(_bsz/1024) + 'kb tools=' + Math.round(_tsz/1024) + 'kb | ' + new Date().toISOString().slice(11,19));

  let lastErr = null;
  for (const { backend, model } of chain) {
    const label = backend + '/' + model;
    try {
      const upstream = await tryBackend(backend, model, req.body, stream);
      if (upstream.ok) {
        stats.byModel[label] = (stats.byModel[label] || 0) + 1;
        console.log('[router] OK -> ' + label);
        if (stream) {
          res.setHeader('Content-Type', 'text/event-stream');
          res.setHeader('Cache-Control', 'no-cache');
          upstream.body.pipe(res);
          // Count streaming request (no token data available without parsing stream)
          trackTokens(backend, model, null);
        } else {
          const data = await upstream.json();
          if (data.choices) data._router = { backend, model, type };
          res.status(200).json(data);
          // Track token usage from response
          trackTokens(backend, model, data.usage || null);
        }
        return;
      }
      const errText = await upstream.text();
      lastErr = upstream.status + ': ' + errText.slice(0, 2000);
      console.log('[router] FAIL ' + label + ': ' + lastErr.slice(0, 500));
    } catch (e) {
      const msg = e.message || '';
      if (msg.startsWith('COOLDOWN:') || msg.startsWith('INACTIVE:')) {
        console.log('[router] SKIP ' + label + ' (' + msg.split(':')[0] + ')');
      } else {
        console.log('[router] ERR ' + label + ': ' + msg);
      }
      lastErr = msg;
    }
  }

  stats.errors++;
  res.status(503).json({ error: { message: 'All backends failed. Last: ' + lastErr, type: 'router_exhausted' } });
});

// ── STATS DATA BUILDER ────────────────────────────────────────────────────────
function buildStatsData() {
  checkDayReset();
  const activeBackends = Object.entries(BACKENDS)
    .filter(([, b]) => b.active()).map(([name]) => name);

  const models = {};
  // Merge daily + total usage across all known keys
  const allKeys = new Set([...Object.keys(dailyUsage), ...Object.keys(totalUsage), ...Object.keys(LIMITS)]);
  for (const key of allKeys) {
    const lim  = LIMITS[key] || {};
    const day  = dailyUsage[key] || { req: 0, prompt: 0, completion: 0, total: 0 };
    const tot  = totalUsage[key] || { req: 0, prompt: 0, completion: 0, total: 0 };
    const reqRemain  = lim.reqDay != null ? Math.max(0, lim.reqDay - day.req) : null;
    const tokRemain  = lim.tokDay != null ? Math.max(0, lim.tokDay - day.total) : null;
    const reqPct     = lim.reqDay ? Math.min(100, Math.round(day.req / lim.reqDay * 100)) : null;
    const tokPct     = lim.tokDay ? Math.min(100, Math.round(day.total / lim.tokDay * 100)) : null;
    models[key] = { day, total: tot, limits: lim, reqRemain, tokRemain, reqPct, tokPct };
  }

  return {
    uptime_s: Math.floor((Date.now() - stats.startTime) / 1000),
    date: dailyDate,
    active_backends: activeBackends,
    total_requests: stats.requests,
    total_errors: stats.errors,
    by_type: stats.byType,
    models,
    cooldowns: Object.fromEntries(
      Object.entries(cooldowns)
        .filter(([, v]) => Date.now() < v)
        .map(([k, v]) => [k, Math.ceil((v - Date.now()) / 1000) + 's'])
    ),
  };
}

// ── JSON STATS ENDPOINT ───────────────────────────────────────────────────────
app.get('/stats', (_req, res) => res.json(buildStatsData()));

// ── HEALTH ENDPOINT ───────────────────────────────────────────────────────────
app.get('/health', (_req, res) => {
  const activeBackends = Object.entries(BACKENDS)
    .filter(([, b]) => b.active()).map(([name]) => name);
  res.json({ ok: true, uptime_s: Math.floor((Date.now() - stats.startTime) / 1000), active_backends: activeBackends, stats, cooldowns });
});

app.get('/v1/models', (_req, res) => {
  res.json({ object: 'list', data: [{ id: 'gpt-4o', object: 'model', owned_by: 'router' }] });
});

// ── SEND STATS TO TELEGRAM ────────────────────────────────────────────────────
async function sendTelegramStats() {
  const d = buildStatsData();
  const upH = Math.floor(d.uptime_s / 3600);
  const upM = Math.floor((d.uptime_s % 3600) / 60);

  let text = `*Статистика токенів* (${d.date})\n`;
  text += `Uptime: ${upH}г ${upM}хв | Запитів: ${d.total_requests} | Помилок: ${d.total_errors}\n`;
  text += `Активних: ${d.active_backends.join(', ')}\n\n`;

  // Show only models that were actually used today, sorted by requests desc
  const used = Object.entries(d.models)
    .filter(([, v]) => v.day.req > 0)
    .sort(([, a], [, b]) => b.day.req - a.day.req);

  if (used.length === 0) {
    text += '_Сьогодні ще не було запитів_\n';
  } else {
    for (const [key, v] of used) {
      const shortKey = key.replace('moonshotai/', '').replace('meta-llama/', '').replace(':free', '');
      const bar = v.reqPct != null
        ? '[' + '▓'.repeat(Math.round(v.reqPct / 10)) + '░'.repeat(10 - Math.round(v.reqPct / 10)) + '] ' + v.reqPct + '%'
        : '';
      const reqInfo = v.limits.reqDay
        ? `${v.day.req}/${v.limits.reqDay} req (залишилось: ${v.reqRemain})`
        : `${v.day.req} req`;
      const tokInfo = v.day.total > 0
        ? ` | ${(v.day.total/1000).toFixed(1)}k токенів`
        : '';
      text += `*${shortKey}*\n${bar}\n${reqInfo}${tokInfo}\n\n`;
    }
  }

  if (Object.keys(d.cooldowns).length > 0) {
    text += `Cooldowns: ${Object.entries(d.cooldowns).map(([k,v]) => k.split('/').slice(-1)[0]+': '+v).join(', ')}\n`;
  }

  const payload = {
    chat_id: TG_CHAT,
    text,
    parse_mode: 'Markdown',
    reply_markup: JSON.stringify({
      inline_keyboard: [[
        { text: '📊 Детальна сторінка', url: `http://${SERVER_IP}:9001/` },
        { text: '🔄 Оновити', url: 'http://68.183.66.2:9001/' },
      ]]
    }),
  };

  await fetch(`https://api.telegram.org/bot${TG_BOT}/sendMessage`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  });
}

// ── ENDPOINT TO TRIGGER TELEGRAM STATS ───────────────────────────────────────
app.post('/send-stats', async (_req, res) => {
  try {
    await sendTelegramStats();
    res.json({ ok: true });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// ── HTML STATS PAGE (port 9001, public) ───────────────────────────────────────
function buildHtml() {
  const d = buildStatsData();
  const upH = Math.floor(d.uptime_s / 3600);
  const upM = Math.floor((d.uptime_s % 3600) / 60);

  const providerColors = {
    github: '#24292e', gemini: '#4285f4', groq: '#f55036',
    cerebras: '#7b2fff', openrouter: '#6366f1', mistral: '#ff7000',
    together: '#1a1a2e', sambanova: '#00a67e',
  };

  const allModels = Object.entries(d.models).sort(([, a], [, b]) => (b.day.req + b.total.req) - (a.day.req + a.total.req));

  let rows = '';
  for (const [key, v] of allModels) {
    const [backend] = key.split('/');
    const color = providerColors[backend] || '#666';
    const modelShort = key.split('/').slice(1).join('/').replace(':free','');

    const reqBar = v.reqPct != null
      ? `<div class="bar-wrap"><div class="bar" style="width:${v.reqPct}%;background:${color}"></div></div>`
      : '<div class="bar-wrap"><div class="bar bar-unlimited" style="width:30%;background:${color}99"></div></div>';

    const reqText = v.limits.reqDay
      ? `${v.day.req} / ${v.limits.reqDay} <span class="remain">(${v.reqRemain} залишилось)</span>`
      : `${v.day.req} <span class="unlimited">без ліміту</span>`;

    const tokText = v.day.total > 0
      ? `${(v.day.total/1000).toFixed(1)}k сьогодні / ${(v.total.total/1000).toFixed(1)}k всього`
      : `—`;

    const tokBarHtml = v.tokPct != null
      ? `<div class="bar-wrap tok-bar"><div class="bar" style="width:${v.tokPct}%;background:${color}99"></div></div>`
      : '';

    const isActive = d.active_backends.includes(backend) ? '' : ' inactive';
    const isCool = d.cooldowns[key] ? ` <span class="cool-badge">cooldown ${d.cooldowns[key]}</span>` : '';

    rows += `
      <tr class="model-row${isActive}">
        <td><span class="badge" style="background:${color}">${backend}</span><br><span class="model-name">${modelShort}</span>${isCool}</td>
        <td>${reqText}${reqBar}</td>
        <td>${tokText}${tokBarHtml}</td>
        <td class="center">${v.total.req}</td>
      </tr>`;
  }

  const typeRows = Object.entries(d.by_type)
    .map(([t, n]) => `<span class="type-badge">${t}: ${n}</span>`).join(' ');

  return `<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Smart Router — Статистика</title>
<meta http-equiv="refresh" content="30">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f1117; color: #e2e8f0; min-height: 100vh; }
  .header { background: linear-gradient(135deg, #1e2130 0%, #252840 100%); padding: 24px 32px; border-bottom: 1px solid #2d3148; }
  .header h1 { font-size: 22px; font-weight: 700; color: #fff; }
  .header .sub { color: #8892a4; font-size: 13px; margin-top: 4px; }
  .meta { display: flex; gap: 24px; margin-top: 16px; flex-wrap: wrap; }
  .meta-item { background: #1a1d2e; border: 1px solid #2d3148; border-radius: 8px; padding: 10px 16px; }
  .meta-item .val { font-size: 22px; font-weight: 700; color: #7dd3fc; }
  .meta-item .lbl { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
  .content { padding: 24px 32px; }
  .section-title { font-size: 13px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 12px; }
  table { width: 100%; border-collapse: collapse; background: #1a1d2e; border: 1px solid #2d3148; border-radius: 10px; overflow: hidden; }
  thead th { background: #252840; padding: 10px 14px; text-align: left; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
  tr.model-row td { padding: 12px 14px; border-top: 1px solid #252840; vertical-align: middle; }
  tr.model-row.inactive { opacity: .4; }
  tr.model-row:hover { background: #252840; }
  .badge { display: inline-block; padding: 2px 7px; border-radius: 4px; font-size: 10px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: .5px; }
  .model-name { font-size: 12px; color: #94a3b8; margin-top: 3px; display: block; }
  .bar-wrap { height: 6px; background: #2d3148; border-radius: 3px; margin-top: 6px; overflow: hidden; }
  .bar { height: 100%; border-radius: 3px; transition: width .3s; }
  .tok-bar { margin-top: 4px; opacity: .6; }
  .remain { color: #4ade80; font-size: 12px; }
  .unlimited { color: #7dd3fc; font-size: 12px; }
  .cool-badge { display: inline-block; background: #7c3aed22; color: #a78bfa; border: 1px solid #7c3aed55; border-radius: 4px; padding: 1px 6px; font-size: 10px; margin-left: 6px; }
  .center { text-align: center; color: #64748b; }
  .type-badge { display: inline-block; background: #1e3a5f; color: #7dd3fc; padding: 3px 10px; border-radius: 4px; font-size: 12px; margin: 2px; }
  .types-row { margin-bottom: 20px; }
  .refresh-note { text-align: center; color: #334155; font-size: 11px; padding: 16px; }
  .active-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .chip { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; color: #fff; }
  .cooldowns-row { background: #1a1d2e; border: 1px solid #7c3aed55; border-radius: 8px; padding: 10px 14px; margin-bottom: 20px; color: #a78bfa; font-size: 13px; display: none; }
  .cooldowns-row.visible { display: block; }
</style>
</head>
<body>
<div class="header">
  <h1>Smart Router — Статистика токенів</h1>
  <div class="sub">Оновлюється кожні 30 секунд | ${new Date().toLocaleString('uk-UA')}</div>
  <div class="meta">
    <div class="meta-item"><div class="val">${d.total_requests}</div><div class="lbl">Запитів всього</div></div>
    <div class="meta-item"><div class="val">${d.total_errors}</div><div class="lbl">Помилок</div></div>
    <div class="meta-item"><div class="val">${upH}г ${upM}хв</div><div class="lbl">Uptime</div></div>
    <div class="meta-item"><div class="val">${d.date}</div><div class="lbl">День (скидається опівночі)</div></div>
  </div>
</div>
<div class="content">
  <div class="section-title">Активні backends</div>
  <div class="active-chips">
    ${d.active_backends.map(b => `<div class="chip" style="background:${providerColors[b]||'#666'}">${b}</div>`).join('')}
  </div>

  ${Object.keys(d.cooldowns).length > 0 ? `
  <div class="cooldowns-row visible">
    Cooldowns: ${Object.entries(d.cooldowns).map(([k,v]) => `<b>${k.split('/').pop()}</b>: ${v}`).join(' &nbsp;|&nbsp; ')}
  </div>` : ''}

  <div class="section-title">Типи запитів сьогодні</div>
  <div class="types-row">${typeRows || '<span style="color:#334155">—</span>'}</div>

  <div class="section-title">Використання по моделях (сьогодні)</div>
  <table>
    <thead>
      <tr>
        <th>Модель</th>
        <th>Запити (сьогодні / ліміт)</th>
        <th>Токени (сьогодні / всього)</th>
        <th>Всього запитів</th>
      </tr>
    </thead>
    <tbody>${rows}</tbody>
  </table>
  <div class="refresh-note">Автооновлення кожні 30 сек</div>
</div>
</body>
</html>`;
}

statsApp.get('/', (_req, res) => {
  res.setHeader('Content-Type', 'text/html; charset=utf-8');
  res.send(buildHtml());
});

statsApp.get('/api', (_req, res) => res.json(buildStatsData()));

// ── TELEGRAM CALLBACK QUERY HANDLER ──────────────────────────────────────────
// Handles "refresh" button presses relayed from Telegram webhook
app.post('/tg-callback', express.json(), async (req, res) => {
  const cb = req.body?.callback_query;
  if (cb?.data === 'refresh_stats') {
    try {
      // Answer the callback (removes loading spinner on button)
      await fetch(`https://api.telegram.org/bot${TG_BOT}/answerCallbackQuery`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ callback_query_id: cb.id, text: 'Оновлюю...', show_alert: false }),
      });
      // Edit the original message with fresh stats
      const d = buildStatsData();
      const upH = Math.floor(d.uptime_s / 3600);
      const upM = Math.floor((d.uptime_s % 3600) / 60);
      let text = `*Статистика токенів* (${d.date}) — оновлено ${new Date().toLocaleTimeString('uk-UA')}\n`;
      text += `Uptime: ${upH}г ${upM}хв | Запитів: ${d.total_requests} | Помилок: ${d.total_errors}\n\n`;
      const used = Object.entries(d.models)
        .filter(([, v]) => v.day.req > 0)
        .sort(([, a], [, b]) => b.day.req - a.day.req);
      if (used.length === 0) { text += '_Сьогодні ще не було запитів_'; }
      else {
        for (const [key, v] of used) {
          const shortKey = key.replace('moonshotai/', '').replace('meta-llama/', '').replace(':free', '');
          const bar = v.reqPct != null
            ? '[' + '▓'.repeat(Math.round(v.reqPct / 10)) + '░'.repeat(10 - Math.round(v.reqPct / 10)) + '] ' + v.reqPct + '%'
            : '';
          const reqInfo = v.limits.reqDay
            ? `${v.day.req}/${v.limits.reqDay} req (залишилось: ${v.reqRemain})`
            : `${v.day.req} req`;
          const tokInfo = v.day.total > 0 ? ` | ${(v.day.total/1000).toFixed(1)}k токенів` : '';
          text += `*${shortKey}*\n${bar}\n${reqInfo}${tokInfo}\n\n`;
        }
      }
      await fetch(`https://api.telegram.org/bot${TG_BOT}/editMessageText`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          chat_id: cb.message.chat.id,
          message_id: cb.message.message_id,
          text,
          parse_mode: 'Markdown',
          reply_markup: JSON.stringify({
            inline_keyboard: [[
              { text: '📊 Детальна сторінка', url: `http://${SERVER_IP}:9001/` },
              { text: '🔄 Оновити', url: 'http://68.183.66.2:9001/' },
            ]]
          }),
        }),
      });
    } catch (e) { console.error('[tg-callback] error:', e.message); }
  }
  res.json({ ok: true });
});

