// Backends that do NOT support function calling tools
const NO_TOOLS_BACKENDS = new Set(['cerebras', 'mistral', 'together', 'sambanova']);

// Compress tool schemas aggressively: strip ALL descriptions, keep names+types only
// Reduces tools from ~50kb to ~3kb
function stripParamDescriptions(schema) {
  if (!schema || typeof schema !== 'object') return schema;
  const out = {};
  for (const [k, v] of Object.entries(schema)) {
    if (k === 'description') continue; // strip all descriptions
    if (k === 'properties' && typeof v === 'object') {
      out.properties = Object.fromEntries(
        Object.entries(v).map(([pk, pv]) => [pk, stripParamDescriptions(pv)])
      );
    } else if (k === 'items') {
      out.items = stripParamDescriptions(v);
    } else {
      out[k] = v;
    }
  }
  return out;
}

function compressTools(tools) {
  if (!tools || !tools.length) return tools;
  // Standard compression: strip all descriptions
  const standard = tools.map(t => {
    const fn = t.function || t;
    return {
      type: t.type || 'function',
      function: {
        name: fn.name,
        description: (fn.description || '').slice(0, 60),
        parameters: stripParamDescriptions(fn.parameters || { type: 'object', properties: {} }),
      },
    };
  });
  // Emergency compression: if still > 8kb, keep only name + required params (no schemas)
  if (JSON.stringify(standard).length > 8000) {
    return tools.map(t => {
      const fn = t.function || t;
      const props = (fn.parameters || {}).properties || {};
      const req   = (fn.parameters || {}).required || [];
      const minProps = {};
      for (const k of req) { if (props[k]) minProps[k] = { type: props[k].type || 'string' }; }
      return {
        type: t.type || 'function',
        function: {
          name: fn.name,
          parameters: { type: 'object', properties: minProps, required: req },
        },
      };
    });
  }
  return standard;
}




// ── GEMINI SCHEMA SANITIZATION ──────────────────────────────────────────────
// Universal tool schema sanitizer.
// OpenAI/GitHub REQUIRE additionalProperties:false on every object schema.
// Gemini (OpenAI-compat endpoint) supports this since Nov 2025.
// Both support anyOf. Strip only truly universal junk: $schema/$id/$defs/$ref etc.
function sanitizeSchema(schema) {
  if (!schema || typeof schema !== 'object' || Array.isArray(schema)) return schema;
  const out = {};
  for (const [k, v] of Object.entries(schema)) {
    // Strip unsupported meta-schema fields universally
    if (['$schema','$id','$defs','$ref','unevaluatedProperties',
         'if','then','else','examples'].includes(k)) continue;
    // Normalize additionalProperties: always false (OpenAI requires it, Gemini now supports it)
    if (k === 'additionalProperties') {
      out.additionalProperties = false;
      continue;
    }
    // Skip empty required arrays
    if (k === 'required' && Array.isArray(v) && v.length === 0) continue;
    // Recurse into properties
    if (k === 'properties' && typeof v === 'object' && !Array.isArray(v)) {
      out.properties = Object.fromEntries(
        Object.entries(v).map(([pk, pv]) => [pk, sanitizeSchema(pv)])
      );
    } else if (k === 'items') {
      out.items = Array.isArray(v) ? v.map(s => sanitizeSchema(s)) : sanitizeSchema(v);
    } else if ((k === 'anyOf' || k === 'oneOf' || k === 'allOf') && Array.isArray(v)) {
      const cleaned = v.map(s => sanitizeSchema(s));
      if (cleaned.length > 0) out[k] = cleaned;
    } else {
      out[k] = v;
    }
  }
  // OpenAI requires additionalProperties:false on all object schemas
  if (out.type === 'object' && !('additionalProperties' in out)) {
    out.additionalProperties = false;
  }
  return out;
}

function sanitizeToolsForGemini(tools) {
  if (!tools || !tools.length) return tools;
  return tools.map(t => {
    const fn = t.function || t;
    return {
      type: t.type || 'function',
      function: {
        name: fn.name,
        description: (fn.description || '').slice(0, 1024),
        parameters: sanitizeSchema(fn.parameters || { type: 'object', properties: {}, additionalProperties: false }),
      },
    };
  });
}

function estTokens(obj) {
  return Math.ceil(JSON.stringify(obj).length / 3.5);
}

// ── SMART CONTEXT COMPRESSION ────────────────────────────────────────────────
// Strategy:
//   1. Keep system prompt
//   2. Keep first user message (original goal)
//   3. Keep last 10 messages (recent context / current tool loop)
//   4. Drop everything in the middle
//   5. Trim individual messages that are too large (huge tool outputs)
const MAX_MSG_TOK = 2000;

function trimSingleMsg(msg) {
  const c = typeof msg.content === 'string' ? msg.content : JSON.stringify(msg.content);
  if (c.length / 3.5 <= MAX_MSG_TOK) return msg;
  return { ...msg, content: c.slice(0, MAX_MSG_TOK * 3) + '\n[...trimmed...]' };
}

function estTok(msg) {
  const c = typeof msg.content === 'string' ? msg.content : JSON.stringify(msg.content || '');
  return Math.ceil(c.length / 3.5) + 10;
}

function smartCompress(messages, tokenBudget) {
  if (!messages || messages.length === 0) return messages;
  const budget = Math.max(tokenBudget || 2000, 800);

  const system = messages.filter(m => m.role === 'system');
  const nonSys = messages.filter(m => m.role !== 'system');
  if (nonSys.length === 0) return messages;

  // Trim individual oversized messages (tool outputs, etc.)
  const maxMsgTok = Math.min(MAX_MSG_TOK, Math.floor(budget * 0.4));
  function trim(msg) {
    const c = typeof msg.content === 'string' ? msg.content : JSON.stringify(msg.content || '');
    if (c.length / 3.5 <= maxMsgTok) return msg;
    return { ...msg, content: c.slice(0, maxMsgTok * 3) + '[...trimmed]' };
  }

  // Build from recent backwards until budget is exhausted
  const sysTok   = system.reduce((s, m) => s + estTok(m), 0);
  let remaining  = budget - sysTok - 50; // 50 for compression note
  const kept     = [];

  for (let i = nonSys.length - 1; i >= 0 && remaining > 0; i--) {
    const trimmed = trim(nonSys[i]);
    const t = estTok(trimmed);
    if (t > remaining && kept.length > 0) break; // stop if no budget, but keep at least 1
    remaining -= t;
    kept.unshift(trimmed);
  }

  // Remove leading orphaned tool results
  while (kept.length > 0 && kept[0].role === 'tool') kept.shift();

  const dropped = nonSys.length - kept.length;
  if (dropped === 0) return [...system, ...kept];

  const note = { role: 'system', content: '[Context: ' + dropped + ' older messages omitted]' };
  const result = [...system, note, ...kept];
  const usedTok = Math.round(JSON.stringify(result).length / 3.5);
  console.log('[router] compressed ' + dropped + ' msgs -> ~' + usedTok + ' tok (budget=' + budget + ')');
  return result;
}


// ── TOKEN TRACKING ───────────────────────────────────────────────────────────
let dailyDate   = new Date().toDateString();
let dailyUsage  = {};  // resets each day
let totalUsage  = {};  // all-time, never resets
const stats = { requests: 0, byType: {}, byModel: {}, errors: 0, startTime: Date.now() };

function checkDayReset() {
  const today = new Date().toDateString();
  if (dailyDate !== today) { dailyDate = today; dailyUsage = {}; }
}

function trackTokens(backend, model, usage) {
  checkDayReset();
  const key = backend + '/' + model;
  const empty = () => ({ req: 0, prompt: 0, completion: 0, total: 0 });
  if (!dailyUsage[key]) dailyUsage[key] = empty();
  if (!totalUsage[key]) totalUsage[key] = empty();

  dailyUsage[key].req++;
  totalUsage[key].req++;

  if (usage) {
    const p = usage.prompt_tokens || 0;
    const c = usage.completion_tokens || 0;
    const t = usage.total_tokens || (p + c);
    dailyUsage[key].prompt     += p;
    dailyUsage[key].completion += c;
    dailyUsage[key].total      += t;
    totalUsage[key].prompt     += p;
    totalUsage[key].completion += c;
    totalUsage[key].total      += t;
  }
}

// ── COOLDOWN ─────────────────────────────────────────────────────────────────
const cooldowns = {};
function isOnCooldown(k) { return Date.now() < (cooldowns[k] || 0); }
function setCooldown(k, sec) {
  cooldowns[k] = Date.now() + (sec + 2) * 1000;
  console.log('[router] cooldown: ' + k + ' for ' + sec + 's');
}

// ── STAGE-AWARE MODEL ROUTING ────────────────────────────────────────────────
// Stages:
//   execution   — assistant is running tools in a loop → FAST models
//   verification— user asks to check/verify results   → SMART models
//   code/task/analysis/chat — keyword-based for new requests
function makeChain(...candidates) {
  return candidates.filter(({ backend }) => BACKENDS[backend] && BACKENDS[backend].active());
}

