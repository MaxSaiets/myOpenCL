      "name": "health-check",
      "description": "Verify smart-router + pm2 services every 15min",
      "enabled": false,
      "createdAtMs": 1774183093192,
      "updatedAtMs": 1774212133413,
      "schedule": {
        "kind": "cron",
        "expr": "*/15 * * * *"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "System health check: 1) Test http://127.0.0.1:9000/health - if no response, restart smart-router. 2) Run pm2 status. If everything ok reply HEARTBEAT_OK, else describe the issue briefly.",
        "lightContext": true
      },
      "delivery": {
        "mode": "announce",
        "channel": "telegram",
        "chatId": "1311004971"
      },
      "state": {
