{"type":"message","id":"90f9d5d3","parentId":"7444d553","timestamp":"2026-03-22T19:00:30.358Z","message":{"role":"assistant","content":[{"type":"text","text":"Роблю: створюю Python-скрипт для обробки AKSAN логів з Telegram бота."},{"type":"toolCall","id":"functions.write:0","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nAKSAN Telegram Bot Log Processor\n\nАналізує логи з Telegram бота AKSAN:\n- Рахує кількість повідомлень\n- Визначає активність користувачів\n- Шукає помилки\n- Генерує статистику\n\"\"\"\n\nimport json\nimport re\nimport sys\nfrom collections import Counter, defaultdict\nfrom datetime import datetime\nfrom pathlib import Path\n\n\nclass AKSANLogProcessor:\n    def __init__(self, log_file_path):\n        self.log_file_path = Path(log_file_path)\n        self.messages = []\n        self.errors = []\n        self.user_activity = defaultdict(int)\n        self.hourly_activity = Counter()\n        \n    def parse_log_line(self, line):\n        \"\"\"Парсить один рядок логу\"\"\"\n        # Приклад формату: 2024-10-24 14:30:25 INFO User 123456789: /start\n        pattern = r'(\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2})\\s+(\\w+)\\s+(.+)'\n        match = re.match(pattern, line.strip())\n        \n        if match:\n            timestamp_str, level, message = match.groups()\n            try:\n                timestamp = datetime.strptime(timestamp_str, '%Y-%m-%d %H:%M:%S')\n                return {\n                    'timestamp': timestamp,\n                    'level': level,\n                    'message': message,\n                    'raw': line.strip()\n                }\n            except ValueError:\n                return None\n        return None\n    \n    def extract_user_id(self, message):\n        \"\"\"Витягує ID користувача з повідомлення\"\"\"\n        # Шукаємо ID після слова User\n        match = re.search(r'User\\s+(\\d+)', message)\n        return match.group(1) if match else None\n    \n    def extract_command(self, message):\n        \"\"\"Витягує команду з повідомлення\"\"\"\n        # Шукаємо команди, що починаються з /\n        match = re.search(r'(/\\w+)', message)\n        return match.group(1) if match else None\n    \n    def process_logs(self):\n        \"\"\"Обробляє всі логи з файлу\"\"\"\n        if not self.log_file_path.exists():\n            print(f\"❌ Файл {self.log_file_path} не знайдено\")\n            return False\n            \n        try:\n            with open(self.log_file_path, 'r', encoding='utf-8') as f:\n                lines = f.readlines()\n        except Exception as e:\n            print(f\"❌ Помилка читання файлу: {e}\")\n            return False\n        \n        for line_num, line in enumerate(lines, 1):\n            parsed = self.parse_log_line(line)\n            if parsed:\n                self.messages.append(parsed)\n                \n                # Збираємо статистику\n                user_id = self.extract_user_id(parsed['message'])\n                if user_id:\n                    self.user_activity[user_id] += 1\n                \n                # Годинна активність\n                hour_key = parsed['timestamp'].strftime('%Y-%m-%d %H:00')\n                self.hourly_activity[hour_key] += 1\n                \n                # Збираємо помилки\n                if parsed['level'] in ['ERROR', 'CRITICAL']:\n                    self.errors.append({\n                        'line': line_num,\n                        'timestamp': parsed['timestamp'],\n                        'message': parsed['message']\n                    })\n        \n        return True\n    \n    def generate_stats(self):\n        \"\"\"Генерує статистику\"\"\"\n        if not self.messages:\n            return \"Немає даних для аналізу\"\n        \n        total_messages = len(self.messages)\n        unique_users = len(self.user_activity)\n        error_count = len(self.errors)\n        \n        # Часовий діапазон\n        first_msg = min(msg['timestamp'] for msg in self.messages)\n        last_msg = max(msg['timestamp'] for msg in self.messages)\n        duration = last_msg - first_msg\n        \n        stats = []\n        stats.append(\"📊 СТАТИСТИКА AKSAN BOT\")\n        stats.append(\"=\" * 30)\n        stats.append(f\"📈 Всього повідомлень: {total_messages}\")\n        stats.append(f\"👥 Унікальних користувачів: {unique_users}\")\n        stats.append(f\"❌ Помилок: {error_count}\")\n        stats.append(f\"📅 Період: {first_msg.strftime('%Y-%m-%d')} - {last_msg.strftime('%Y-%m-%d')}\")\n        stats.append(f\"⏱ Тривалість: {duration}\")\n        stats.append(\"\")\n        \n        # Топ активних користувачів\n        if self.user_activity:\n            stats.append(\"🔥 ТОП КОРИСТУВАЧІВ:\")\n            for user_id, count in sorted(self.user_activity.items(), key=lambda x: x[1], reverse=True)[:10]:\n                stats.append(f\"   User {user_id}: {count} повідомлень\")\n            stats.append(\"\")\n        \n        # Годинна активність\n        if self.hourly_activity:\n            stats.append(\"📊 ГОДИННА АКТИВНІСТЬ:\")\n            for hour, count in sorted(self.hourly_activity.items())[-24:]:  # Останні 24 години\n                stats.append(f\"   {hour}: {count} повідомлень\")\n            stats.append(\"\")\n        \n        # Команди\n        commands = Counter()\n        for msg in self.messages:\n            cmd = self.extract_command(msg['message'])\n            if cmd:\n                commands[cmd] += 1\n        \n        if commands:\n            stats.append(\"🎮 ПОПУЛЯРНІ КОМАНДИ:\")\n            for cmd, count in sorted(commands.items(), key=lambda x: x[1], reverse=True)[:10]:\n                stats.append(f\"   {cmd}: {count} разів\")\n            stats.append(\"\")\n        \n        # Помилки\n        if self.errors:\n            stats.append(\"🚨 ПОМИЛКИ:\")\n            for error in self.errors[-10:]:  # Останні 10 помилок\n                stats.append(f\"   {error['timestamp']}: {error['message']}\")\n            stats.append(\"\")\n        \n        return \"\\n\".join(stats)\n    \n    def export_json(self, output_file):\n        \"\"\"Експортує дані в JSON\"\"\"\n        data = {\n            'stats': {\n                'total_messages': len(self.messages),\n                'unique_users': len(self.user_activity),\n                'error_count': len(self.errors),\n                'period': {\n                    'start': min(msg['timestamp'] for msg in self.messages).isoformat(),\n                    'end': max(msg['timestamp'] for msg in self.messages).isoformat()\n                }\n            },\n            'user_activity': dict(self.user_activity),\n            'hourly_activity': dict(self.hourly_activity),\n            'errors': [\n                {\n                    'timestamp': err['timestamp'].isoformat(),\n                    'message': err['message'],\n                    'line': err['line']\n                }\n                for err in self.errors\n            ]\n        }\n        \n        with open(output_file, 'w', encoding='utf-8') as f:\n            json.dump(data, f, ensure_ascii=False, indent=2)\n        \n        return f\"✅ Дані експортовано в {output_file}\"\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print(\"Використання: python aksan_log_processor.py <шлях_до_лог_файлу> [output.json]\")\n        sys.exit(1)\n    \n    log_file = sys.argv[1]\n    output_json = sys.argv[2] if len(sys.argv) > 2 else None\n    \n    processor = AKSANLogProcessor(log_file)\n    \n    print(f\"🔄 Обробка логів з {log_file}...\")\n    if not processor.process_logs():\n        sys.exit(1)\n    \n    # Виводимо статистику\n    print(processor.generate_stats())\n    \n    # Експортуємо в JSON якщо потрібно\n    if output_json:\n        print(processor.export_json(output_json))\n\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"router","model":"gpt-4o","usage":{"input":22,"output":2149,"cacheRead":6656,"cacheWrite":0,"totalTokens":8827,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774206023815,"responseId":"chatcmpl-89e08714-5325-4af3-8351-cae8f719cdcf"}}
