map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

# HTTP → redirect to HTTPS + keep health check
server {
    listen 80;
    server_name _;

    location /health-check {
        return 200 '{"service":"openclaw-gateway","status":"ok"}';
        add_header Content-Type application/json;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — main server (self-signed cert for Telegram webhook)
server {
    listen 443 ssl;
    server_name _;

    ssl_certificate     /etc/ssl/claw-cert.pem;
    ssl_certificate_key /etc/ssl/claw-key.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    location /health-check {
        return 200 '{"service":"openclaw-gateway","status":"ok"}';
        add_header Content-Type application/json;
    }

    # Telegram webhook endpoint → OpenClaw gateway
    location /telegram-webhook {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }

    location /ws {
        proxy_pass http://127.0.0.1:18789;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:9000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
    }

    location / {
        return 200 '{"service":"openclaw-gateway","status":"ok"}';
        add_header Content-Type application/json;
    }
}
